  <!-- ── Path B: GTK icon-theme extraction source ─────────────────────────
       Application::on_activate reads each of these from the bundle and
       writes it to ~/.local/share/icons/hicolor/scalable/apps/, then
       calls gtk_icon_theme_add_search_path so GTK's icon-theme machinery
       can resolve the icons by name. This is the bridge that makes
       set_icon_name("curvz-select-symbolic") work — GTK's lookup is
       rigid about the hicolor/scalable/apps/ shape, so we mirror that
       shape on disk at first run.

       The prefix here MUST match what on_activate passes to
       g_resources_lookup_data: /com/curvz/app/icons/scalable/apps/.
       Don't change the prefix without updating Application.cpp. -->
  <gresource prefix="/com/curvz/app/icons/scalable/apps">
    <file preprocess="xml-stripblanks" alias="curvz-select-symbolic.svg">icons/curvz-select-symbolic.svg</file>
