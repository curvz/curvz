    <!-- s152: snap toggle icons. Drawn by Scott as a mirror pair (pill
         outline; "on" voids the right-side and fills the left, "off" is
         the mirror). currentColor fill so they paint against the
         active-state foreground (white on var(--accent-deep) when the
         snap toggle is :checked, var(--fg-muted)/var(--fg-primary)
         otherwise). Originally drawn at 1000×1000 viewBox in curvz
         itself; the data-curvz-* metadata that ships with curvz-export
         was stripped before bundling because GTK4's symbolic-icon
         validator rejected the metadata wrappers. -->
    <file preprocess="xml-stripblanks" alias="curvz-switch-on-symbolic.svg">icons/curvz-switch-on-symbolic.svg</file>
    <file preprocess="xml-stripblanks" alias="curvz-switch-off-symbolic.svg">icons/curvz-switch-off-symbolic.svg</file>
