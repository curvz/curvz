{
  "_legend_01": "═══════════════════════════════════════════════════════════════════════",
  "_legend_02": "  CURVZ STARTER TEMPLATES  —  seeds.json  —  field reference",
  "_legend_03": "═══════════════════════════════════════════════════════════════════════",
  "_legend_04": "",
  "_legend_05": "TOP LEVEL",
  "_legend_06": "  version   integer  required  currently 1",
  "_legend_07": "  defaults  object   optional  proportions applied to any seed that",
  "_legend_08": "                               doesn't carry its own 'proportions' block",
  "_legend_09": "  seeds     array    required  list of seed objects",
  "_legend_10": "",
  "_legend_11": "SEED OBJECT",
  "_legend_12": "  category     string   required   one of: icons | print | web | social",
  "_legend_13": "                                  (or any custom name — becomes a folder)",
  "_legend_14": "  name         string   required   display name; used to form the slug",
  "_legend_15": "                                  (e.g. 'My Card' → 'my-card.curvztpl')",
  "_legend_16": "  description  string   optional   short spec text, shown in UI",
  "_legend_17": "  canvas       object   required   see CANVAS below",
  "_legend_18": "  proportions  object   optional   per-seed override of defaults",
  "_legend_19": "",
  "_legend_20": "CANVAS OBJECT",
  "_legend_21": "  kind         string   required   one of: ratio | pixel | physical",
  "_legend_22": "",
  "_legend_23": "  when kind = 'ratio'  (aspect-ratio based, best for icons)",
  "_legend_24": "    width      number  required   positive real, e.g. 16 or 1.618",
  "_legend_25": "    height     number  required   positive real, e.g. 9  or 1.0",
  "_legend_26": "    quality    integer required   pixels on the short axis, e.g. 1000",
  "_legend_27": "",
  "_legend_28": "  when kind = 'pixel'  (literal pixel size, best for web / social)",
  "_legend_29": "    width      integer required   positive, in pixels",
  "_legend_30": "    height     integer required   positive, in pixels",
  "_legend_31": "",
  "_legend_32": "  when kind = 'physical'  (print / stationery)",
  "_legend_33": "    width      number  required   positive real, in 'unit'",
  "_legend_34": "    height     number  required   positive real, in 'unit'",
  "_legend_35": "    unit       string  required   one of: in | mm | cm",
  "_legend_36": "    dpi        integer optional   default 300; typical: 72 | 150 | 300 | 600",
  "_legend_37": "",
  "_legend_38": "PROPORTIONS OBJECT  (grid + margin computed at instantiation time)",
  "_legend_39": "  grid_divisions     integer  optional   ≥ 0; default 0 = disabled",
  "_legend_40": "                                         cells across the short axis",
  "_legend_41": "  margin_ratio       number   optional   0.0–1.0; default 0.0 = disabled",
  "_legend_42": "                                         margin = grid_cell × margin_ratio",
  "_legend_43": "                                         applied to all four sides equally",
  "_legend_44": "  grid_offset_ratio  number   optional   0.0–1.0; default 0.0",
  "_legend_45": "                                         grid origin offset as fraction",
  "_legend_46": "                                         of a cell (0.5 centers on margin)",
  "_legend_47": "",
  "_legend_48": "INHERITANCE",
  "_legend_49": "  A seed without a 'proportions' block inherits the 'defaults' block.",
  "_legend_50": "  A seed with a partial 'proportions' block inherits missing fields:",
  "_legend_51": "    \"proportions\": { \"grid_divisions\": 12 }",
  "_legend_52": "    → uses 12 divisions, inherits margin_ratio + grid_offset_ratio.",
  "_legend_53": "  Disable proportions entirely for one seed:",
  "_legend_54": "    \"proportions\": { \"grid_divisions\": 0, \"margin_ratio\": 0 }",
  "_legend_55": "",
  "_legend_56": "HOUSE STYLE  (the bundled defaults)",
  "_legend_57": "  10 divisions across the short axis, margin = half a cell, grid offset",
  "_legend_58": "  half a cell. On US Letter → 0.425in margins; on a 1000q icon → 50px.",
  "_legend_59": "",
  "_legend_60": "LIFECYCLE",
  "_legend_61": "  • Edit this file freely; delete ~/.config/curvz/templates/.seeds_v1",
  "_legend_62": "    to re-seed on next launch.",
  "_legend_63": "  • Existing bundles are never overwritten; only missing ones created.",
  "_legend_64": "  • Broken JSON falls back to the bundled copy (seeding still works).",
  "_legend_65": "  • Keys starting with _ are ignored by the parser — use them for notes.",
  "_legend_66": "",
  "_legend_67": "═══════════════════════════════════════════════════════════════════════",

